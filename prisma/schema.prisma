datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Program {
  id          String   @id @default(uuid())
  name        String
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  totalRows       Int      @default(0)
  fieldCount      Int      @default(0)
  errorCount      Int      @default(0)
  uniqueKeyColumn String   @default("")  // nama kolom ID unik, contoh: "NIK"
  headers         String[] @default([])
  status          ProgramStatus @default(ACTIVE)

  // Relasi ke tabel terpisah
  participants    Participant[]
  profileSchema   ProfileSchema?
  profileTemplateId String?
  profileTemplate   ProfileTemplate? @relation(fields: [profileTemplateId], references: [id], onDelete: SetNull)
  importLogs      ImportLog[]
  programMembers  ProgramMember[]
  activityLogs    ActivityLog[]

  @@index([createdAt(sort: Desc)])
}

// ─────────────────────────────────────────────
// Model: Participant
// ─────────────────────────────────────────────
model Participant {
  id              String   @id @default(cuid())
  programId       String
  program         Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  rowIndex        Int      // urutan asli dari Excel (0-based)
  uniqueKey       String   // nilai kolom ID unik (contoh: NIK, No. Peserta)

  data            Json     // semua field Excel: { "Nama": "...", "Alamat": "...", ... }

  // Kolom evaluasi — terpisah dari data{}, bisa di-index dan query langsung
  evalStatus      ParticipantEvalStatus?
  evalDescription String?
  evalByUserId    String?
  evalByUserName  String?
  evalAt          DateTime?

  // Untuk full-text search: concat semua value dari data{}
  searchText      String   @default("")

  importedAt      DateTime @default(now())

  @@unique([programId, uniqueKey])       // enforce unique key per program di DB level
  @@unique([programId, rowIndex])        // enforce urutan unik per program
  @@index([programId])
  @@index([programId, evalStatus])       // filter/stats by status
  @@index([programId, rowIndex])         // navigasi prev/next
}

// ─────────────────────────────────────────────
// Model: ProfileSchema
// ─────────────────────────────────────────────
model ProfileSchema {
  id        String   @id @default(uuid())
  programId String   @unique
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  sections  Json     // Section[] — array konfigurasi layout
  version   Int      @default(1)
  updatedAt DateTime @updatedAt

  @@index([programId])
}

// ─────────────────────────────────────────────
// Model: ImportLog
// ─────────────────────────────────────────────
model ImportLog {
  id         String       @id @default(uuid())
  programId  String
  program    Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  importedAt DateTime     @default(now())
  fileName   String
  totalRows  Int
  errorCount Int
  status     ImportStatus @default(COMPLETED)
  notes      String?

  @@index([programId])
  @@index([importedAt(sort: Desc)])
}

enum ImportStatus {
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}

// Better Auth Models
model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions       Session[]
  accounts       Account[]
  programMembers ProgramMember[]
  activityLogs   ActivityLog[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}


// ─────────────────────────────────────────────
// Model: ProgramMember
// ─────────────────────────────────────────────
model ProgramMember {
  id        String   @id @default(uuid())
  programId String
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ProgramMemberRole
  status    ProgramMemberStatus
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([programId, userId])
  @@index([programId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// Model: ActivityLog
// ─────────────────────────────────────────────
model ActivityLog {
  id        String   @id @default(uuid())
  programId String
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // e.g. "VERIFIED_PARTICIPANT", "REJECTED_PARTICIPANT"
  details   String   // Detail/keterangan aktivitas (misal: "Memverifikasi NIK 123456")
  createdAt DateTime @default(now())

  @@index([programId])
  @@index([createdAt(sort: Desc)])
}

enum ProgramMemberRole {
  ADMIN
  VERIFIER
}

enum ProgramMemberStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ParticipantEvalStatus {
  VERIFIED
  REJECTED
}

enum ProgramStatus {
  ACTIVE
  STOPPED
}

// ─────────────────────────────────────────────
// Model: ProfileTemplate
// ─────────────────────────────────────────────
model ProfileTemplate {
  id          String    @id @default(uuid())
  name        String
  description String    @default("")
  sections    Json      // Section[] — array konfigurasi layout
  version     Int       @default(1)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  programs    Program[]
}





